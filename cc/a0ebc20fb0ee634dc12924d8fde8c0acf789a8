e-id\".to_string(), \"trace-abc-123\".to_string());\n\n    pub_\n        .publish_with_headers::<WorkTopic>(\n            &SimpleMessage { id: \"hdr-1\".into(), content: \"with headers\".into() },\n            headers,\n        )\n        .await\n        .expect(\"publish_with_headers should succeed\");\n\n    let captured = Arc::new(Mutex::new(HashMap::new()));\n    let handler = HeaderCapture(captured.clone());\n\n    let shutdown = CancellationToken::new();\n    let sc = shutdown.clone();\n\n    let consumer = NatsConsumer::new(client.clone());\n    let handle = tokio::spawn(async move {\n        consumer.run::<WorkTopic>(handler, ConsumerOptions::new(sc).with_prefetch_count(1)).await\n    });\n\n    let result = tokio::time::timeout(TIMEOUT, async {\n        loop {\n            let map = captured.lock().await;\n            if !map.is_empty() { return map.clone(); }\n            drop(map);\n            tokio::time::sleep(Duration::from_millis(100)).await;\n        }\n    })\n    .await;\n\n    shutdown.cancel();\n    handle.await.unwrap().ok();\n\n    let headers_received = result.expect(\"should receive headers within timeout\");\n    assert_eq!(\n        headers_received.get(\"x-trace-id\").map(|s| s.as_str()),\n        Some(\"trace-abc-123\"),\n    );\n    client.shutdown().await;\n}\n\n#[tokio::test]\nasync fn publish_and_consume_batch() {\n    let client = connect().await;\n    declare::<WorkTopic>(&client).await;\n\n    let pub_ = publisher(&client);\n    let messages: Vec<SimpleMessage> = (1..=5)\n        .map(|i| SimpleMessage {\n            id: format!(\"batch-{i}\"),\n            content: format!(\"message {i}\"),\n        })\n        .collect();\n\n    pub_\n        .publish_batch::<WorkTopic>(&messages)\n        .await\n        .expect(\"publish_batch should succeed\");\n\n    let handler = CountingHandler::new();\n    let hc = handler.clone();\n    let shutdown = CancellationToken::new();\n    let sc = shutdown.clone();\n\n    let consumer = NatsConsumer::new(client.clone());\n    let handle = tokio::spawn(async move {\n        consumer.run::<WorkTopic>(hc, ConsumerOptions::new(sc).with_prefetch_count(10)).await\n    });\n\n    assert!(handler.counter.wait_for(5, TIMEOUT).await, \"should receive all 5 messages\");\n\n    shutdown.cancel();\n    handle.await.unwrap().ok();\n    assert_eq!(handler.counter.get(), 5);\n    client.shutdown().await;\n}\n```\n\n- [ ] **Step 2: Verify it compiles**\n\nRun: `cargo test -q --features nats --test nats_integration --no-run`\n\n- [ ] **Step 3: Commit**\n\n```bash\ngit add tests/nats_integration.rs\ngit commit -m \"test(nats): add publish/consume, headers, and batch tests\"\n```\n\n---\n\n### Task 4: Rejection, DLQ, retry, and defer tests (tests 9–13)\n\n**Files:**\n- Modify: `tests/nats_integration.rs`\n\n- [ ] **Step 1: Add rejection, DLQ, retry, and defer tests**\n\nAppend to `tests/nats_integration.rs`:\n\n```rust\n// ===========================================================================\n// Rejection & DLQ\n// ===========================================================================\n\n#[tokio::test]\nasync fn rejected_message_lands_in_dlq() {\n    let client = connect().await;\n    declare::<WorkTopic>(&client).await;\n\n    let pub_ = publisher(&client);\n    pub_\n        .publish::<WorkTopic>(&SimpleMessage { id: \"reject-1\".into(), content: \"reject me\".into() })\n        .await\n        .unwrap();\n\n    let shutdown = CancellationToken::new();\n    let sc = shutdown.clone();\n\n    let consumer = NatsConsumer::new(client.clone());\n    let handle = tokio::spawn(async move {\n        consumer\n            .run::<WorkTopic>(\n                FixedOutcomeHandler(Outcome::Reject),\n                ConsumerOptions::new(sc).with_prefetch_count(1).with_max_retries(1),\n            )\n            .await\n    });\n\n    // Verify message arrives in DLQ via a DLQ consumer\n    let dlq_handler = DlqRecordingHandler::new();\n    let dhc = dlq_handler.clone();\n    l