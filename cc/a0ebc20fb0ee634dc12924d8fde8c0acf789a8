     max_retries: options.max_retries,\n                        prefetch_count: options.prefetch_count,\n                        shutdown: options.shutdown.clone(),\n                        processing: options.processing.clone(),\n                        handler_timeout: options.handler_timeout,\n                        max_pending_per_key: options.max_pending_per_key,\n                        exactly_once: options.exactly_once,\n                        receive_batch_size: options.receive_batch_size,\n                    };\n\n                    tokio::spawn(async move {\n                        options_ref.processing.store(true, std::sync::atomic::Ordering::Relaxed);\n                        let outcome = invoke_handler(&*handler, payload, metadata, timeout).await;\n                        route_outcome(&client, &msg, outcome, topology, retry_count, &options_ref).await;\n                        options_ref.processing.store(false, std::sync::atomic::Ordering::Relaxed);\n                        drop(permit);\n                    });\n                }\n            }\n        }\n    }\n\n    async fn run_fifo<T: SequencedTopic>(\n        &self,\n        handler: impl MessageHandler<T>,\n        options: ConsumerOptions,\n    ) -> Result<()> {\n        // Placeholder — implemented in Task 6\n        todo!()\n    }\n\n    async fn run_dlq<T: Topic>(\n        &self,\n        handler: impl MessageHandler<T>,\n    ) -> Result<()> {\n        // Placeholder — implemented in Task 6\n        todo!()\n    }\n}\n```\n\n- [ ] **Step 2: Verify it compiles**\n\nRun: `cargo check -q --features nats`\nExpected: compiles (run_fifo and run_dlq are `todo!()` stubs)\n\n- [ ] **Step 3: Commit**\n\n```bash\ngit add src/backends/nats/consumer.rs\ngit commit -m \"feat(nats): implement NatsConsumer::run() with concurrent processing\"\n```\n\n---\n\n### Task 6: NatsConsumer — `run_fifo()` and `run_dlq()`\n\n**Files:**\n- Modify: `src/backends/nats/consumer.rs`\n\n- [ ] **Step 1: Implement `run_fifo()`**\n\nReplace the `run_fifo` placeholder in the `Consumer` impl block with:\n\n```rust\n    async fn run_fifo<T: SequencedTopic>(\n        &self,\n        handler: impl MessageHandler<T>,\n        options: ConsumerOptions,\n    ) -> Result<()> {\n        let topology = T::topology();\n        let queue = topology.queue();\n        let seq = topology\n            .sequencing()\n            .expect(\"run_fifo requires a sequenced topology\");\n        let handler = Arc::new(handler);\n        let client = self.client.clone();\n\n        let stream = client\n            .jetstream()\n            .get_stream(queue)\n            .await\n            .map_err(|e| ShoveError::Connection(format!(\"failed to get stream '{queue}': {e}\")))?;\n\n        let mut shard_tasks = Vec::new();\n\n        for shard in 0..seq.routing_shards() {\n            let consumer_name = format!(\"{queue}-shard-{shard}\");\n            let filter_subject = format!(\"{queue}.shard.{shard}\");\n\n            let pull_consumer = stream\n                .get_or_create_consumer(\n                    &consumer_name,\n                    PullConsumerConfig {\n                        durable_name: Some(consumer_name.clone()),\n                        filter_subject: filter_subject.clone(),\n                        ack_policy: AckPolicy::Explicit,\n                        max_ack_pending: 1, // Sequential per shard\n                        ..Default::default()\n                    },\n                )\n                .await\n                .map_err(|e| {\n                    ShoveError::Connection(format!(\n                        \"failed to create shard consumer '{consumer_name}': {e}\"\n                    ))\n                })?;\n\n            let handler = handler.clone();\n            let client = client.clone();\n            let shutdown = options.shutdown.clone();\n            let processing = options.processing.clone();\n            let max_retries = options.max_retries;\n            