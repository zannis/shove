equenced FIFO consumption\n// ---------------------------------------------------------------------------\n\n#[tokio::test]\nasync fn sequenced_consume_preserves_order() {\n    let broker = TestBroker::start().await;\n    let setup = TestSetup::new(&broker).await;\n    setup.declare::<SeqSkipTopic>().await;\n\n    let publisher = SnsPublisher::new(setup.client.clone(), setup.topic_registry.clone());\n\n    // Publish 5 messages with the same order_id (same sequence key → same shard)\n    for i in 0..5u64 {\n        let msg = OrderMessage {\n            order_id: \"ORD-A\".into(),\n            amount: i + 1,\n        };\n        publisher\n            .publish::<SeqSkipTopic>(&msg)\n            .await\n            .expect(\"publish should succeed\");\n        // Small delay to ensure ordering in FIFO\n        tokio::time::sleep(Duration::from_millis(50)).await;\n    }\n\n    let handler = OrderRecordingHandler::new();\n    let records = handler.records.clone();\n    let shutdown = CancellationToken::new();\n    let sc = shutdown.clone();\n\n    let consumer = SqsConsumer::new(setup.client.clone(), setup.queue_registry.clone());\n    let handle = tokio::spawn(async move {\n        consumer\n            .run_fifo::<SeqSkipTopic>(\n                handler,\n                ConsumerOptions::new(sc).with_prefetch_count(10),\n            )\n            .await\n    });\n\n    tokio::time::timeout(Duration::from_secs(30), async {\n        while records.lock().await.len() < 5 {\n            tokio::time::sleep(Duration::from_millis(200)).await;\n        }\n    })\n    .await\n    .expect(\"timed out waiting for 5 sequenced messages\");\n\n    shutdown.cancel();\n    let _ = handle.await;\n\n    let recs = records.lock().await;\n    assert_eq!(recs.len(), 5);\n\n    // Verify ordering — amounts should be 1,2,3,4,5 for the same key\n    let amounts: Vec<u64> = recs.iter().map(|(_, a)| *a).collect();\n    assert_eq!(amounts, vec![1, 2, 3, 4, 5], \"messages should be in order\");\