    ))\n            })?;\n\n        let attrs = result.attributes().unwrap_or(&std::collections::HashMap::new());\n\n        let ready = attrs\n            .get(&aws_sdk_sqs::types::QueueAttributeName::ApproximateNumberOfMessages)\n            .and_then(|v| v.parse::<u64>().ok())\n            .unwrap_or(0);\n\n        let not_visible = attrs\n            .get(&aws_sdk_sqs::types::QueueAttributeName::ApproximateNumberOfMessagesNotVisible)\n            .and_then(|v| v.parse::<u64>().ok())\n            .unwrap_or(0);\n\n        debug!(\n            queue_name,\n            messages_ready = ready,\n            messages_not_visible = not_visible,\n            \"fetched SQS queue stats\"\n        );\n\n        Ok(SqsQueueStats {\n            messages_ready: ready,\n            messages_not_visible: not_visible,\n        })\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn queue_stats_defaults() {\n        let stats = SqsQueueStats::default();\n        assert_eq!(stats.messages_ready, 0);\n        assert_eq!(stats.messages_not_visible, 0);\n    }\n}\n```\n\n- [ ] **Step 2: Add module to mod.rs**\n\nAdd `pub mod stats;` to `src/backends/sns/mod.rs`.\n\n- [ ] **Step 3: Verify**\n\nRun: `cargo -q check --features sns`\nRun: `cargo -q test --features sns --lib backends::sns::stats`\n\n- [ ] **Step 4: Commit**\n\n```bash\ngit add src/backends/sns/stats.rs src/backends/sns/mod.rs\ngit commit -m \"feat(sns): implement SQS queue stats provider\"\n```\n\n---\n\n### Task 9: Wire Up Exports\n\n**Files:**\n- Modify: `src/lib.rs`\n- Modify: `src/backends/sns/mod.rs`\n\n- [ ] **Step 1: Update lib.rs re-exports**\n\nUpdate the `#[cfg(feature = \"sns\")]` block in `src/lib.rs`:\n\n```rust\n#[cfg(feature = \"sns\")]\npub mod sns {\n    pub use crate::backends::sns::{\n        client::{SnsClient, SnsConfig},\n        consumer::SqsConsumer,\n        consumer_group::{SqsConsumerGroup, SqsConsumerGroupConfig},\n        publisher::SnsPublisher,\n        registry::