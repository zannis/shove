ic>().await;\n\n    // FIFO topic ARN\n    let arn = setup\n        .topic_registry\n        .get(\"sqs-seq-skip\")\n        .await\n        .expect(\"FIFO topic ARN should be registered\");\n    assert!(arn.contains(\"sqs-seq-skip.fifo\"));\n\n    // Shard queue URLs (2 shards)\n    for i in 0..2 {\n        let shard_name = format!(\"sqs-seq-skip-seq-{i}\");\n        let url = setup\n            .queue_registry\n            .get(&shard_name)\n            .await\n            .unwrap_or_else(|| panic!(\"shard queue '{shard_name}' should be registered\"));\n        assert!(!url.is_empty());\n    }\n\n    // DLQ should exist\n    let dlq_url = setup\n        .queue_registry\n        .get(\"sqs-seq-skip-dlq\")\n        .await\n        .expect(\"DLQ for sequenced topic should be registered\");\n    assert!(!dlq_url.is_empty());\n}\n\n#[tokio::test]\nasync fn topology_idempotent_with_queues() {\n    let broker = TestBroker::start().await;\n    let setup = TestSetup::new(&broker).await;\n\n    // Declare twice — should not error\n    setup.declare::<WorkTopic>().await;\n    setup.declare::<WorkTopic>().await;\n\n    let url = setup\n        .queue_registry\n        .get(\"sqs-work\")\n        .await\n        .expect(\"queue should still be registered\");\n    assert!(!url.is_empty());\n}\n```\n\n- [ ] **Step 2: Run and verify**\n\nRun: `cargo -q test --features aws-sns-sqs --test sns_sqs_integration -- topology_ --test-threads=1`\nExpected: 3 tests pass\n\n- [ ] **Step 3: Commit**\n\n```bash\ngit add tests/sns_sqs_integration.rs\ngit commit -m \"test(sns-sqs): topology declaration with SQS queues, DLQ, and FIFO shards\"\n```\n\n---\n\n### Task 4: Publish and Consume (Basic)\n\n**Files:**\n- Modify: `tests/sns_sqs_integration.rs`\n\n- [ ] **Step 1: Add basic publish/consume tests**\n\n```rust\n// ---------------------------------------------------------------------------\n// Basic publish & consume\n// ---------------------------------------------------------------------------\n\n#[tokio::test]\nasync fn publish_and_consume_simple_message() {\n    let broker = TestBroker::start().await;\n    let setup = TestSetup::new(&broker).await;\n    setup.declare::<WorkTopic>().await;\n\n    let msg = SimpleMessage {\n        id: \"msg-1\".into(),\n        content: \"hello\".into(),\n    };\n    setup\n        .publisher\n        .publish::<WorkTopic>(&msg)\n        .await\n        .expect(\"publish should succeed\");\n\n    let handler = CountingHandler::new();\n    let count = handler.count.clone();\n    let shutdown = CancellationToken::new();\n    let shutdown_clone = shutdown.clone();\n\n    let consumer = SqsConsumer::new(setup.client.clone(), setup.queue_registry.clone());\n    let handle = tokio::spawn(async move {\n        consumer\n            .run::<WorkTopic>(\n                handler,\n                ConsumerOptions::new(shutdown_clone).with_prefetch_count(1),\n            )\n            .await\n    });\n\n    // Wait for the message to be consumed\n    tokio::time::timeout(Duration::from_secs(15), async {\n        while count.load(Ordering::SeqCst) < 1 {\n            tokio::time::sleep(Duration::from_millis(100)).await;\n        }\n    })\n    .await\n    .expect(\"timed out waiting for message consumption\");\n\n    shutdown.cancel();\n    handle.await.unwrap().expect(\"consumer should exit cleanly\");\n\n    assert_eq!(count.load(Ordering::SeqCst), 1);\n}\n\n#[tokio::test]\nasync fn publish_and_consume_with_headers() {\n    let broker = TestBroker::start().await;\n    let setup = TestSetup::new(&broker).await;\n    setup.declare::<WorkTopic>().await;\n\n    let mut headers = HashMap::new();\n    headers.insert(\"x-trace-id\".to_string(), \"trace-abc\".to_string());\n\n    let msg = SimpleMessage {\n        id: \"msg-h\".into(),\n        content: \"with headers\".into(),\n    };\n    setup\n        .publisher\n        .publish_with_headers::<WorkTopic>(&msg, headers)\n        .await\n        .expect(\"publish with headers should 