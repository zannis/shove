k.\n#[derive(Clone)]\nstruct RetryThenAckHandler {\n    retry_until: u32,\n    attempt_count: Arc<AtomicU32>,\n    ack_count: Arc<AtomicU32>,\n    signal: Arc<tokio::sync::Notify>,\n}\n\nimpl RetryThenAckHandler {\n    fn new(retry_until: u32) -> Self {\n        Self {\n            retry_until,\n            attempt_count: Arc::new(AtomicU32::new(0)),\n            ack_count: Arc::new(AtomicU32::new(0)),\n            signal: Arc::new(tokio::sync::Notify::new()),\n        }\n    }\n    fn ack_count(&self) -> u32 { self.ack_count.load(Ordering::Relaxed) }\n}\n\n// Implement for RetryWork\nimpl MessageHandler<RetryWork> for RetryThenAckHandler {\n    async fn handle(&self, _msg: SimpleMessage, _meta: MessageMetadata) -> Outcome {\n        let attempt = self.attempt_count.fetch_add(1, Ordering::Relaxed);\n        if attempt < self.retry_until {\n            Outcome::Retry\n        } else {\n            self.ack_count.fetch_add(1, Ordering::Relaxed);\n            self.signal.notify_waiters();\n            Outcome::Ack\n        }\n    }\n}\n\n/// Handler that returns Defer once, then Ack on redelivery.\n#[derive(Clone)]\nstruct DeferOnceHandler {\n    deferred: Arc<std::sync::Mutex<std::collections::HashSet<String>>>,\n    ack_count: Arc<AtomicU32>,\n    signal: Arc<tokio::sync::Notify>,\n}\n\nimpl DeferOnceHandler {\n    fn new() -> Self {\n        Self {\n            deferred: Arc::new(std::sync::Mutex::new(std::collections::HashSet::new())),\n            ack_count: Arc::new(AtomicU32::new(0)),\n            signal: Arc::new(tokio::sync::Notify::new()),\n        }\n    }\n    fn ack_count(&self) -> u32 { self.ack_count.load(Ordering::Relaxed) }\n}\n```\n\nYou'll need separate impl blocks for `DeferNoHold` and `DeferWithHold` topics. Both do the same thing: first time a delivery_id is seen → Defer, second time → Ack.\n\nAlso implement `MessageHandler<ScalableWork>` for `CountingHandler` (same as the SimpleWork impl).\n\nAlso implement `MessageHandler<AuditedWork>` for `Coun